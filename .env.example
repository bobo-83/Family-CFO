# Family CFO deployment configuration.
#
# Copy to .env and fill in real values. .env is gitignored; never commit secrets.
#
#   cp .env.example .env
#   docker compose up -d

# --- Database ---------------------------------------------------------------
POSTGRES_USER=family_cfo
POSTGRES_DB=family_cfo
# REQUIRED: set a strong password. The stack refuses to start without it.
POSTGRES_PASSWORD=change-me

# --- Backups ----------------------------------------------------------------
# Fernet key for encrypted backups. Generate one with:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Leave empty to run the stack without backups (backup jobs will fail until set).
# WARNING: losing this key makes existing backups permanently unrecoverable.
FAMILY_CFO_BACKUP_ENCRYPTION_KEY=
FAMILY_CFO_BACKUP_RETENTION_COUNT=7

# --- App --------------------------------------------------------------------
FAMILY_CFO_LOG_LEVEL=INFO

# Host port the dashboard is published on (http://localhost:${WEB_PORT}).
WEB_PORT=8080

# Dev-only (docker-compose.dev.yml): host port for the API and vLLM model.
API_PORT=8000
# VLLM_MODEL=meta-llama/Llama-3.2-3B-Instruct
