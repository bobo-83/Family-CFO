# Family CFO deployment configuration.
#
# Copy to .env and fill in real values. .env is gitignored; never commit secrets.
#
#   cp .env.example .env
#   docker compose up -d

# --- Database ---------------------------------------------------------------
POSTGRES_USER=family_cfo
POSTGRES_DB=family_cfo
# REQUIRED: set a strong password. The stack refuses to start without it.
POSTGRES_PASSWORD=change-me

# --- Backups ----------------------------------------------------------------
# Fernet key for encrypted backups. Generate one with:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Leave empty to run the stack without backups (backup jobs will fail until set).
# WARNING: losing this key makes existing backups permanently unrecoverable.
FAMILY_CFO_BACKUP_ENCRYPTION_KEY=
FAMILY_CFO_BACKUP_RETENTION_COUNT=7

# --- App --------------------------------------------------------------------
FAMILY_CFO_LOG_LEVEL=INFO

# Session token lifetime in hours (login/refresh issue tokens with this TTL).
FAMILY_CFO_SESSION_TTL_HOURS=12

# Set to "production" to disable the Swagger UI and openapi.json (ADR 0010).
# FAMILY_CFO_ENV=production

# --- Security (ADR 0010) ----------------------------------------------------
# Login brute-force guard (in-memory, single-instance). On by default.
# FAMILY_CFO_AUTH_RATE_LIMIT_ENABLED=true
# FAMILY_CFO_AUTH_RATE_LIMIT_MAX_ATTEMPTS=5
# FAMILY_CFO_AUTH_RATE_LIMIT_WINDOW_SECONDS=300
# FAMILY_CFO_AUTH_RATE_LIMIT_LOCKOUT_SECONDS=900
# Max accepted upload size in bytes (imports/documents). Keep in sync with
# client_max_body_size in docker/web-nginx.conf if you raise it.
# FAMILY_CFO_MAX_UPLOAD_BYTES=10000000
# SSRF guard: comma-separated allowlist of base_urls a household may point its
# AI runtime at. Empty = only the deployment default (FAMILY_CFO_AI_BASE_URL).
# FAMILY_CFO_AI_ALLOWED_BASE_URLS=http://vllm:8000

# --- Web / TLS --------------------------------------------------------------
# The dashboard is served over HTTPS at https://localhost:${WEB_TLS_PORT}.
# Plain HTTP on ${WEB_PORT} redirects to HTTPS.
WEB_PORT=8080
WEB_TLS_PORT=8443
# Common Name for the auto-generated self-signed certificate. For a real
# deployment, mount your own cert/key (tls.crt / tls.key) into the web_certs
# volume, or front the stack with an external TLS proxy — see ADR 0008.
TLS_CERT_CN=family-cfo.local
# Extra hostnames/IPs the box is reached by (comma-separated), added to the
# certificate's Subject Alternative Names. REQUIRED for iOS/Safari — and for the
# over-the-air app install — when you connect by LAN IP, because modern clients
# validate the hostname against the SAN and ignore the CN. Set it to your box's
# LAN IP and any DNS aliases, e.g. TLS_CERT_SAN=192.168.1.50,my-box
# Changing it and regenerating the cert rotates the fingerprint, so paired
# phones must re-pair (the pin rotates on re-pair by design).
TLS_CERT_SAN=

# Dev-only (docker-compose.dev.yml): host port for the API.
API_PORT=8000

# Local AI runtime — ON BY DEFAULT. The stack starts a vLLM service and the API
# is wired to use it, so this stack assumes a GPU-capable host. The M16 agentic
# advisor needs a tool-calling-capable model AND a matching vLLM tool parser.
# The default model is ungated so it works on first boot; override to swap:
#   Qwen/Qwen2.5-32B-Instruct  -> VLLM_TOOL_PARSER=hermes       (default, ungated)
#   Qwen/Qwen2.5-72B-Instruct  -> VLLM_TOOL_PARSER=hermes       (ungated; use a 4-bit quant to save VRAM)
#   meta-llama/Llama-3.3-70B-Instruct -> VLLM_TOOL_PARSER=llama3_json  (gated: set HUGGING_FACE_HUB_TOKEN)
# VLLM_MODEL=Qwen/Qwen2.5-32B-Instruct
# VLLM_TOOL_PARSER=hermes
# HUGGING_FACE_HUB_TOKEN=            # only needed for gated models
#
# To run WITHOUT AI (no GPU): set the flag below to false and start with
# `docker compose up -d --scale vllm=0`. The app then uses deterministic answers.
# FAMILY_CFO_AI_ENABLED=false

# --- Vision (chat photo attachments, ADR 0011) --------------------------------
# A second small vLLM model describes attached photos for the text-only main
# model. On by default. If VLLM_MODEL itself is vision-capable (e.g. a
# Qwen2.5-VL), set FAMILY_CFO_AI_SUPPORTS_VISION=true instead and disable the
# describer. GPU fractions must sum comfortably under 1.0.
# VLLM_VISION_MODEL=Qwen/Qwen2.5-VL-7B-Instruct
# VLLM_GPU_FRACTION=0.60
# VLLM_VISION_GPU_FRACTION=0.20
# FAMILY_CFO_AI_SUPPORTS_VISION=false
# FAMILY_CFO_AI_VISION_ENABLED=true   # false + `--scale vllm-vision=0` to opt out

# --- Live-data chat tools (ADR 0014; search on by default since M28) ----------
# Exchange rates AND price/web lookups work out of the box: rates via a keyless
# provider (only two currency codes leave the box), prices via the bundled
# self-hosted SearXNG (queries carry only the model-composed item terms).
# FAMILY_CFO_LIVE_DATA_ENABLED=true
# SEARXNG_SECRET=            # random value; deploy.sh generates one
# To opt out of web search: set empty + scale the service to 0:
# FAMILY_CFO_SEARXNG_URL=
#   docker compose up -d --scale searxng=0

# Advisor voice (M31): "playful" (default) or "professional". Tone only — the
# numbers-grounding rules are identical in both.
# FAMILY_CFO_AI_TONE=playful

# M32: single-tenant lockout — POST /households refuses once a household
# exists. Set true only for deliberate multi-household deployments.
# FAMILY_CFO_ALLOW_MULTIPLE_HOUSEHOLDS=false

# --- Monitoring (M67) ---------------------------------------------------------
# Grafana ops dashboards, at https://<server>:${WEB_TLS_PORT}/grafana/ (no
# separate port). Ops metrics only — no household financial data. Anonymous
# viewing is enabled; the admin password gates editing.
# GRAFANA_ADMIN_PASSWORD=change-me
